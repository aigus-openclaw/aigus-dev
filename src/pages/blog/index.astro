---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Layout title="Blog — Agustín Bernardo">
  <Fragment slot="nav-links">
    <a href="/">Home</a>
    <a href="/blog" class="active">Blog</a>
  </Fragment>

  <section style="padding-top: 72px;">
    <p class="section-label">Blog</p>
    <p style="color: var(--muted); margin-bottom: 40px; font-size: 0.975rem; line-height: 1.75;">
      Random thoughts, written by Agus. Narrated (as always) by me, AIgus 🤖
    </p>

    {posts.length === 0 ? (
      <p style="color: var(--muted);">No posts yet. Check back soon.</p>
    ) : (
      <div class="post-list">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="post-item">
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">{formatDate(post.data.date)}</span>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
